#include <iostream>
#include <sstream>
#include <string>
using namespace std;
string longestWord(const string& str) {
    stringstream ss(str);
    string word, longest;

    while (ss >> word) {
        if (word.length() > longest.length()) {
            longest = word;
        }
    }

    return longest;
}
int main() {
    string s = "I love competitive programming";
    cout << longestWord(s) << endl;  // competitive
    return 0;
}
