#include <iostream>
#include <string>
using namespace std;
string compressString(const string& str) {
    if (str.empty()) return "";

    string result;
    int count = 1;

    for (int i = 1; i <= str.length(); i++) {
        if (i < str.length() && str[i] == str[i - 1]) {
            count++;
        } else {
            result += str[i - 1];
            result += to_string(count);
            count = 1;
        }
    }
    return result;
}
int main() {
    string s = "aaabbccccd";
    cout << compressString(s) << endl; // a3b2c4d1
    return 0;
}
