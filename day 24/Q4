#include <iostream>
#include <string>
#include <unordered_set>
using namespace std;

string removeDuplicates(const string& str) {
    unordered_set<char> seen;
    string result;

    for (char ch : str) {
        if (seen.find(ch) == seen.end()) {
            seen.insert(ch);
            result += ch;
        }
    }

    return result;
}

int main() {
    string s = "programming";
    cout << removeDuplicates(s) << endl;  // progamin
    return 0;
}
