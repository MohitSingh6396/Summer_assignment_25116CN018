#include <iostream>
#include <string>
using namespace std;

const int MAX = 100;

struct Ticket
{
    int ticketID;
    string passengerName;
    string destination;
    int seatNumber;
    bool booked;
};

Ticket tickets[MAX];
int totalTickets = 0;
void bookTicket()
{
    if (totalTickets >= MAX)
    {
        cout << "No more tickets can be booked!\n";
        return;
    }

    cout << "\nEnter Ticket ID: ";
    cin >> tickets[totalTickets].ticketID;
    cin.ignore();

    cout << "Enter Passenger Name: ";
    getline(cin, tickets[totalTickets].passengerName);

    cout << "Enter Destination: ";
    getline(cin, tickets[totalTickets].destination);

    cout << "Enter Seat Number: ";
    cin >> tickets[totalTickets].seatNumber;

    tickets[totalTickets].booked = true;
    totalTickets++;

    cout << "Ticket booked successfully!\n";
}
void displayTickets()
{
    if (totalTickets == 0)
    {
        cout << "\nNo bookings found.\n";
        return;
    }

    cout << "\n------ Ticket Bookings ------\n";

    for (int i = 0; i < totalTickets; i++)
    {
        cout << "\nTicket " << i + 1 << endl;
        cout << "Ticket ID      : " << tickets[i].ticketID << endl;
        cout << "Passenger Name : " << tickets[i].passengerName << endl;
        cout << "Destination    : " << tickets[i].destination << endl;
        cout << "Seat Number    : " << tickets[i].seatNumber << endl;
        cout << "Status         : "
             << (tickets[i].booked ? "Booked" : "Cancelled") << endl;
    }
}
void searchTicket()
{
    int id;

    cout << "\nEnter Ticket ID: ";
    cin >> id;

    for (int i = 0; i < totalTickets; i++)
    {
        if (tickets[i].ticketID == id)
        {
            cout << "\nBooking Found!\n";
            cout << "Passenger Name : " << tickets[i].passengerName << endl;
            cout << "Destination    : " << tickets[i].destination << endl;
            cout << "Seat Number    : " << tickets[i].seatNumber << endl;
            cout << "Status         : "
                 << (tickets[i].booked ? "Booked" : "Cancelled") << endl;
            return;
        }
    }

    cout << "Ticket not found!\n";
}
void cancelTicket()
{
    int id;

    cout << "\nEnter Ticket ID to cancel: ";
    cin >> id;

    for (int i = 0; i < totalTickets; i++)
    {
        if (tickets[i].ticketID == id)
        {
            if (!tickets[i].booked)
            {
                cout << "Ticket is already cancelled.\n";
            }
            else
            {
                tickets[i].booked = false;
                cout << "Ticket cancelled successfully.\n";
            }
            return;
        }
    }

    cout << "Ticket not found!\n";
}

void menu()
{
    cout << "\n==============================";
    cout << "\n   TICKET BOOKING SYSTEM";
    cout << "\n==============================";
    cout << "\n1. Book Ticket";
    cout << "\n2. Display All Bookings";
    cout << "\n3. Search Booking";
    cout << "\n4. Cancel Ticket";
    cout << "\n5. Exit";
    cout << "\nEnter your choice: ";
}
int main()
{
    int choice;

    do
    {
        menu();
        cin >> choice;

        switch (choice)
        {
            case 1:
                bookTicket();
                break;

            case 2:
                displayTickets();
                break;

            case 3:
                searchTicket();
                break;

            case 4:
                cancelTicket();
                break;

            case 5:
                cout << "\nThank you for using the Ticket Booking System!\n";
                break;

            default:
                cout << "\nInvalid choice! Please try again.\n";
        }

    } while (choice != 5);

    return 0;
}
