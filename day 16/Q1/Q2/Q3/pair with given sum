#include<bits/stdc++.h>
using namespace std;
bool sum(vector<int>&arr,int target){
    int n= arr.size();
    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){
            if(arr[i]+arr[j]==target){
                return true;
            }
        }
    }
    return false;
}
int main(){
      vector<int> arr  ={1,2,3,5};
      int target=5;
      cout<<sum(arr,target);
    return 0;
}
