#include <iostream>
#include <unordered_map>
#include <vector>
using namespace std;
int maxFrequencyCount(vector<int>& arr) {
    unordered_map<int, int> freq;
    int maxCount = 0;
    for (int x : arr) {
        freq[x]++;
        maxCount = max(maxCount, freq[x]);
    }
    return maxCount;
}
int main() {
    vector<int> arr = {1, 2, 2, 3, 3, 3, 4};
    cout << "Maximum Frequency Count = "
         << maxFrequencyCount(arr);
    return 0;
}
