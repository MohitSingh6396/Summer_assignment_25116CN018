#include<bits/stdc++.h>
using namespace std;
int missing_number(vector<int> & arr){
    int n = arr.size();
    int xor1 =0;
    int xor2 =0;
    for(int i=0;i<n;i++){
        xor1=xor1^(i+1);
        xor2=xor2^arr[i];
    }
    xor1=xor1^(n+1);
    return xor1^xor2;
}
int main(){
    vector<int> arr  ={1,2,3,5};
    cout<<missing_number(arr);
}
