#include <iostream>
#include <algorithm>
#include <string>
using namespace std;

int main() {
    string names[] = {"Ravi", "Aman", "Priya", "Neha"};

    int n = sizeof(names) / sizeof(names[0]);

    sort(names, names + n);

    for (int i = 0; i < n; i++) {
        cout << names[i] << endl;
    }

    return 0;
}
