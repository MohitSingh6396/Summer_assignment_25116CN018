#include <iostream>
#include <string>
using namespace std;

const int MAX = 100;

int roll[MAX];
string name[MAX];
string course[MAX];
float marks[MAX];
int total = 0;
void addStudent()
{
    cout << "\nEnter Roll Number: ";
    cin >> roll[total];
    cin.ignore();

    cout << "Enter Name: ";
    getline(cin, name[total]);

    cout << "Enter Course: ";
    getline(cin, course[total]);

    cout << "Enter Marks: ";
    cin >> marks[total];

    total++;
    cout << "Student Record Added Successfully.\n";
}
void displayStudents()
{
    if (total == 0)
    {
        cout << "\nNo Records Found.\n";
        return;
    }

    cout << "\n----- STUDENT RECORDS -----\n";

    for (int i = 0; i < total; i++)
    {
        cout << "\nRoll No : " << roll[i];
        cout << "\nName    : " << name[i];
        cout << "\nCourse  : " << course[i];
        cout << "\nMarks   : " << marks[i] << endl;
    }
}
void searchStudent()
{
    int r;
    cout << "\nEnter Roll Number: ";
    cin >> r;

    for (int i = 0; i < total; i++)
    {
        if (roll[i] == r)
        {
            cout << "\nRecord Found\n";
            cout << "Roll No : " << roll[i] << endl;
            cout << "Name    : " << name[i] << endl;
            cout << "Course  : " << course[i] << endl;
            cout << "Marks   : " << marks[i] << endl;
            return;
        }
    }

    cout << "Record Not Found.\n";
}
void updateStudent()
{
    int r;
    cout << "\nEnter Roll Number to Update: ";
    cin >> r;
    cin.ignore();

    for (int i = 0; i < total; i++)
    {
        if (roll[i] == r)
        {
            cout << "Enter New Name: ";
            getline(cin, name[i]);

            cout << "Enter New Course: ";
            getline(cin, course[i]);

            cout << "Enter New Marks: ";
            cin >> marks[i];

            cout << "Record Updated Successfully.\n";
            return;
        }
    }

    cout << "Record Not Found.\n";
}
void deleteStudent()
{
    int r;
    cout << "\nEnter Roll Number to Delete: ";
    cin >> r;

    for (int i = 0; i < total; i++)
    {
        if (roll[i] == r)
        {
            for (int j = i; j < total - 1; j++)
            {
                roll[j] = roll[j + 1];
                name[j] = name[j + 1];
                course[j] = course[j + 1];
                marks[j] = marks[j + 1];
            }

            total--;
            cout << "Record Deleted Successfully.\n";
            return;
        }
    }

    cout << "Record Not Found.\n";
}
void menu()
{
    cout << "\n==============================";
    cout << "\n STUDENT MANAGEMENT SYSTEM";
    cout << "\n==============================";
    cout << "\n1. Add Student";
    cout << "\n2. Display Students";
    cout << "\n3. Search Student";
    cout << "\n4. Update Student";
    cout << "\n5. Delete Student";
    cout << "\n6. Exit";
    cout << "\nEnter Choice: ";
}
int main()
{
    int choice;

    do
    {
        menu();
        cin >> choice;

        switch (choice)
        {
            case 1:
                addStudent();
                break;

            case 2:
                displayStudents();
                break;

            case 3:
                searchStudent();
                break;

            case 4:
                updateStudent();
                break;

            case 5:
                deleteStudent();
                break;

            case 6:
                cout << "\nThank You!\n";
                break;

            default:
                cout << "\nInvalid Choice!\n";
        }

    } while (choice != 6);

    return 0;
}
