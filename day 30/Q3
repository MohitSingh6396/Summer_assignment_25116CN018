#include <iostream>
#include <string>
using namespace std;

const int MAX = 100;

int empID[MAX];
string empName[MAX];
string department[MAX];
float salary[MAX];

int totalEmployees = 0;
void addEmployee()
{
    if (totalEmployees >= MAX)
    {
        cout << "Employee list is full!\n";
        return;
    }

    cout << "\nEnter Employee ID: ";
    cin >> empID[totalEmployees];
    cin.ignore();

    cout << "Enter Employee Name: ";
    getline(cin, empName[totalEmployees]);

    cout << "Enter Department: ";
    getline(cin, department[totalEmployees]);

    cout << "Enter Salary: ";
    cin >> salary[totalEmployees];

    totalEmployees++;

    cout << "Employee added successfully!\n";
}
void displayEmployees()
{
    if (totalEmployees == 0)
    {
        cout << "\nNo employee records found.\n";
        return;
    }

    cout << "\n========== EMPLOYEE LIST ==========\n";

    for (int i = 0; i < totalEmployees; i++)
    {
        cout << "\nEmployee " << i + 1 << endl;
        cout << "ID         : " << empID[i] << endl;
        cout << "Name       : " << empName[i] << endl;
        cout << "Department : " << department[i] << endl;
        cout << "Salary     : Rs. " << salary[i] << endl;
    }
}
void searchEmployee()
{
    int id;
    cout << "\nEnter Employee ID: ";
    cin >> id;

    for (int i = 0; i < totalEmployees; i++)
    {
        if (empID[i] == id)
        {
            cout << "\nEmployee Found!\n";
            cout << "ID         : " << empID[i] << endl;
            cout << "Name       : " << empName[i] << endl;
            cout << "Department : " << department[i] << endl;
            cout << "Salary     : Rs. " << salary[i] << endl;
            return;
        }
    }

    cout << "Employee not found!\n";
}
void updateEmployee()
{
    int id;
    cout << "\nEnter Employee ID to Update: ";
    cin >> id;
    cin.ignore();

    for (int i = 0; i < totalEmployees; i++)
    {
        if (empID[i] == id)
        {
            cout << "Enter New Name: ";
            getline(cin, empName[i]);

            cout << "Enter New Department: ";
            getline(cin, department[i]);

            cout << "Enter New Salary: ";
            cin >> salary[i];

            cout << "Employee record updated successfully!\n";
            return;
        }
    }

    cout << "Employee not found!\n";
}
void deleteEmployee()
{
    int id;
    cout << "\nEnter Employee ID to Delete: ";
    cin >> id;

    for (int i = 0; i < totalEmployees; i++)
    {
        if (empID[i] == id)
        {
            for (int j = i; j < totalEmployees - 1; j++)
            {
                empID[j] = empID[j + 1];
                empName[j] = empName[j + 1];
                department[j] = department[j + 1];
                salary[j] = salary[j + 1];
            }

            totalEmployees--;

            cout << "Employee record deleted successfully!\n";
            return;
        }
    }

    cout << "Employee not found!\n";
}
void menu()
{
    cout << "\n==============================";
    cout << "\n EMPLOYEE MANAGEMENT SYSTEM";
    cout << "\n==============================";
    cout << "\n1. Add Employee";
    cout << "\n2. Display Employees";
    cout << "\n3. Search Employee";
    cout << "\n4. Update Employee";
    cout << "\n5. Delete Employee";
    cout << "\n6. Exit";
    cout << "\nEnter your choice: ";
}
int main()
{
    int choice;

    do
    {
        menu();
        cin >> choice;

        switch (choice)
        {
            case 1:
                addEmployee();
                break;

            case 2:
                displayEmployees();
                break;

            case 3:
                searchEmployee();
                break;

            case 4:
                updateEmployee();
                break;

            case 5:
                deleteEmployee();
                break;

            case 6:
                cout << "\nThank you for using Employee Management System!\n";
                break;

            default:
                cout << "\nInvalid choice! Please try again.\n";
        }

    } while (choice != 6);

    return 0;
}
