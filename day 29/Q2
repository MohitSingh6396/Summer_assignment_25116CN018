#include <iostream>
using namespace std;

int arr[100], n;
void inputArray()
{
    cout << "Enter the size of array: ";
    cin >> n;

    cout << "Enter " << n << " elements:\n";
    for (int i = 0; i < n; i++)
    {
        cin >> arr[i];
    }
}
void displayArray()
{
    cout << "\nArray Elements: ";
    for (int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }
    cout << endl;
}
void findMaximum()
{
    int max = arr[0];

    for (int i = 1; i < n; i++)
    {
        if (arr[i] > max)
            max = arr[i];
    }

    cout << "Maximum Element = " << max << endl;
}
void findMinimum()
{
    int min = arr[0];

    for (int i = 1; i < n; i++)
    {
        if (arr[i] < min)
            min = arr[i];
    }

    cout << "Minimum Element = " << min << endl;
}
void findSum()
{
    int sum = 0;

    for (int i = 0; i < n; i++)
    {
        sum += arr[i];
    }

    cout << "Sum = " << sum << endl;
}
void findAverage()
{
    int sum = 0;

    for (int i = 0; i < n; i++)
    {
        sum += arr[i];
    }

    cout << "Average = " << (float)sum / n << endl;
}
void searchElement()
{
    int key;
    cout << "Enter element to search: ";
    cin >> key;

    for (int i = 0; i < n; i++)
    {
        if (arr[i] == key)
        {
            cout << "Element found at position " << i + 1 << endl;
            return;
        }
    }

    cout << "Element not found." << endl;
}
void menu()
{
    cout << "\n==============================";
    cout << "\n   ARRAY OPERATIONS MENU";
    cout << "\n==============================";
    cout << "\n1. Input Array";
    cout << "\n2. Display Array";
    cout << "\n3. Maximum Element";
    cout << "\n4. Minimum Element";
    cout << "\n5. Sum of Elements";
    cout << "\n6. Average";
    cout << "\n7. Search Element";
    cout << "\n8. Exit";
    cout << "\nEnter your choice: ";
}
int main()
{
    int choice;

    do
    {
        menu();
        cin >> choice;

        switch (choice)
        {
            case 1:
                inputArray();
                break;

            case 2:
                displayArray();
                break;

            case 3:
                findMaximum();
                break;

            case 4:
                findMinimum();
                break;

            case 5:
                findSum();
                break;

            case 6:
                findAverage();
                break;

            case 7:
                searchElement();
                break;

            case 8:
                cout << "Program Ended.\n";
                break;

            default:
                cout << "Invalid Choice!\n";
        }

    } while (choice != 8);

    return 0;
}
