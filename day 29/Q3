#include <iostream>
#include <cstring>
using namespace std;
char str1[100], str2[100];
void inputString()
{
    cout << "Enter First String: ";
    cin.ignore();
    cin.getline(str1, 100);

    cout << "Enter Second String: ";
    cin.getline(str2, 100);
}
void displayString()
{
    cout << "\nFirst String  : " << str1 << endl;
    cout << "Second String : " << str2 << endl;
}
void stringLength()
{
    cout << "Length of First String = " << strlen(str1) << endl;
    cout << "Length of Second String = " << strlen(str2) << endl;
}
void copyString()
{
    char copy[100];
    strcpy(copy, str1);

    cout << "Copied String = " << copy << endl;
}
void concatenateString()
{
    char temp[200];
    strcpy(temp, str1);
    strcat(temp, str2);

    cout << "Concatenated String = " << temp << endl;
}
void compareString()
{
    if (strcmp(str1, str2) == 0)
        cout << "Both strings are Equal." << endl;
    else
        cout << "Strings are Not Equal." << endl;
}
void reverseString()
{
    char temp[100];
    strcpy(temp, str1);

    strrev(temp);    // Works in Turbo C++
    cout << "Reversed String = " << temp << endl;
}
void menu()
{
    cout << "\n==============================";
    cout << "\n   STRING OPERATIONS MENU";
    cout << "\n==============================";
    cout << "\n1. Input Strings";
    cout << "\n2. Display Strings";
    cout << "\n3. String Length";
    cout << "\n4. Copy String";
    cout << "\n5. Concatenate Strings";
    cout << "\n6. Compare Strings";
    cout << "\n7. Reverse String";
    cout << "\n8. Exit";
    cout << "\nEnter your choice: ";
}
int main()
{
    int choice;

    do
    {
        menu();
        cin >> choice;

        switch(choice)
        {
            case 1:
                inputString();
                break;

            case 2:
                displayString();
                break;

            case 3:
                stringLength();
                break;

            case 4:
                copyString();
                break;

            case 5:
                concatenateString();
                break;

            case 6:
                compareString();
                break;

            case 7:
                reverseString();
                break;

            case 8:
                cout << "Program Ended!" << endl;
                break;

            default:
                cout << "Invalid Choice!" << endl;
        }

    } while(choice != 8);

    return 0;
}
