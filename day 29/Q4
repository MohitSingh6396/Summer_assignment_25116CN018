#include <iostream>
#include <string>
using namespace std;

const int MAX = 100;

struct Product
{
    int id;
    string name;
    int quantity;
    float price;
};

Product inventory[MAX];
int totalProducts = 0;
void addProduct()
{
    if (totalProducts >= MAX)
    {
        cout << "Inventory is full!\n";
        return;
    }

    cout << "\nEnter Product ID: ";
    cin >> inventory[totalProducts].id;
    cin.ignore();

    cout << "Enter Product Name: ";
    getline(cin, inventory[totalProducts].name);

    cout << "Enter Quantity: ";
    cin >> inventory[totalProducts].quantity;

    cout << "Enter Price: ";
    cin >> inventory[totalProducts].price;

    totalProducts++;

    cout << "Product added successfully!\n";
}
void displayProducts()
{
    if (totalProducts == 0)
    {
        cout << "\nNo products available.\n";
        return;
    }

    cout << "\n========== PRODUCT LIST ==========\n";

    for (int i = 0; i < totalProducts; i++)
    {
        cout << "\nProduct " << i + 1 << endl;
        cout << "ID       : " << inventory[i].id << endl;
        cout << "Name     : " << inventory[i].name << endl;
        cout << "Quantity : " << inventory[i].quantity << endl;
        cout << "Price    : Rs. " << inventory[i].price << endl;
    }
}
void searchProduct()
{
    int id;
    cout << "\nEnter Product ID: ";
    cin >> id;

    for (int i = 0; i < totalProducts; i++)
    {
        if (inventory[i].id == id)
        {
            cout << "\nProduct Found!\n";
            cout << "ID       : " << inventory[i].id << endl;
            cout << "Name     : " << inventory[i].name << endl;
            cout << "Quantity : " << inventory[i].quantity << endl;
            cout << "Price    : Rs. " << inventory[i].price << endl;
            return;
        }
    }

    cout << "Product not found!\n";
}
void updateQuantity()
{
    int id, qty;

    cout << "\nEnter Product ID: ";
    cin >> id;

    for (int i = 0; i < totalProducts; i++)
    {
        if (inventory[i].id == id)
        {
            cout << "Enter New Quantity: ";
            cin >> qty;

            inventory[i].quantity = qty;

            cout << "Quantity updated successfully!\n";
            return;
        }
    }

    cout << "Product not found!\n";
}

void deleteProduct()
{
    int id;

    cout << "\nEnter Product ID to delete: ";
    cin >> id;

    for (int i = 0; i < totalProducts; i++)
    {
        if (inventory[i].id == id)
        {
            for (int j = i; j < totalProducts - 1; j++)
            {
                inventory[j] = inventory[j + 1];
            }

            totalProducts--;

            cout << "Product deleted successfully!\n";
            return;
        }
    }

    cout << "Product not found!\n";
}
void menu()
{
    cout << "\n=================================";
    cout << "\n   INVENTORY MANAGEMENT SYSTEM";
    cout << "\n=================================";
    cout << "\n1. Add Product";
    cout << "\n2. Display Products";
    cout << "\n3. Search Product";
    cout << "\n4. Update Quantity";
    cout << "\n5. Delete Product";
    cout << "\n6. Exit";
    cout << "\nEnter your choice: ";
}
int main()
{
    int choice;

    do
    {
        menu();
        cin >> choice;

        switch (choice)
        {
            case 1:
                addProduct();
                break;

            case 2:
                displayProducts();
                break;

            case 3:
                searchProduct();
                break;

            case 4:
                updateQuantity();
                break;

            case 5:
                deleteProduct();
                break;

            case 6:
                cout << "\nThank you for using Inventory Management System!\n";
                break;

            default:
                cout << "\nInvalid Choice! Please try again.\n";
        }

    } while (choice != 6);

    return 0;
}
