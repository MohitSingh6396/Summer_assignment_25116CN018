#include <iostream>
#include <unordered_set>
using namespace std;
void commonElements(int arr1[], int n1, int arr2[], int n2) {
    unordered_set<int> s;
    for (int i = 0; i < n1; i++)
        s.insert(arr1[i]);
    cout << "Common elements: ";
    for (int i = 0; i < n2; i++) {
        if (s.count(arr2[i])) {
            cout << arr2[i] << " ";
            s.erase(arr2[i]); 
        }
    }
}
int main() {
    int arr1[] = {1, 2, 3, 4, 5};
    int arr2[] = {3, 4, 5, 6, 7};
    commonElements(arr1, 5, arr2, 5);
    return 0;
}
