#include <iostream>
using namespace std;
bool isSymmetric(int A[][10], int n) {
    for (int i = 0; i < n; i++) {
        for (int j = i + 1; j < n; j++) {
            if (A[i][j] != A[j][i]) {
                return false;
            }
        }
    }
    return true;
}
int main() {
    int n;
    cin >> n;

    int A[10][10];

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            cin >> A[i][j];
        }
    }
    if (isSymmetric(A, n))
        cout << "Symmetric Matrix";
    else
        cout << "Not a Symmetric Matrix";
    return 0;
}
