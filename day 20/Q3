#include <iostream>
using namespace std;

void rowSum(int A[][10], int r, int c) {
    for (int i = 0; i < r; i++) {
        int sum = 0;
        for (int j = 0; j < c; j++) {
            sum += A[i][j];
        }
        cout << "Sum of row " << i + 1 << " = " << sum << endl;
    }
}

int main() {
    int r, c;
    cin >> r >> c;

    int A[10][10];

    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            cin >> A[i][j];
        }
    }

    rowSum(A, r, c);

    return 0;
}
