#include <iostream>
#include <string>
using namespace std;

void charFrequency(string str) {
    int freq[256] = {0};

    for (char ch : str) {
        freq[(unsigned char)ch]++;
    }

    cout << "Character Frequencies:\n";
    for (int i = 0; i < 256; i++) {
        if (freq[i] > 0) {
            cout << (char)i << " : " << freq[i] << endl;
        }
    }
}

int main() {
    string str;

    cout << "Enter a string: ";
    getline(cin, str);

    charFrequency(str);

    return 0;
}
