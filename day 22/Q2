#include <iostream>
#include <string>
using namespace std;

int countWords(string sentence) {
    int count = 0;
    bool inWord = false;

    for (char ch : sentence) {
        if (ch != ' ' && !inWord) {
            count++;
            inWord = true;
        } else if (ch == ' ') {
            inWord = false;
        }
    }

    return count;
}

int main() {
    string sentence;

    cout << "Enter a sentence: ";
    getline(cin, sentence);

    cout << "Number of words = " << countWords(sentence);

    return 0;
}
